    "id": "fn_alert_from_motion",
    "type": "function",
    "z": "tab_main",
    "name": "Build alert message",
    "func": "var alerts = flow.get('alerts') || [];\nvar now = new Date().toISOString();\n\nif (msg.payload.detected) {\n    var text = now + \" - MOTION DETECTED\";\n    alerts.unshift(text);\n    alerts = alerts.slice(0, 50);\n    flow.set('alerts', alerts);\n    return { payload: text };\n} else {\n    return null;\n}\n",

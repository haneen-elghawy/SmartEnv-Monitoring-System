  {
    "id": "fn_status",
    "type": "function",
    "z": "tab_main",
    "name": "Format status text",
    "func": "var u = msg.payload.uptime || 0;\nvar rssi = msg.payload.rssi || 0;\nvar heap = msg.payload.freeHeap || 0;\nmsg.payload = \"Uptime: \" + u + \"s  RSSI: \" + rssi + \" dBm  FreeHeap: \" + heap;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 550,
    "y": 380,
    "wires": [["text_status", "trigger_offline"]]
